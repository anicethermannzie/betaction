# =============================================================================
# BetAction — environment variables template
# Copy this file to .env and fill in the values before running docker compose.
# NEVER commit .env to version control.
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=betaction
POSTGRES_PASSWORD=betaction_dev_password
POSTGRES_DB=betaction

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_change_in_production
JWT_REFRESH_SECRET=your_refresh_secret_change_in_production

# ── API Football (RapidAPI) ───────────────────────────────────────────────────
RAPID_API_KEY=your_rapidapi_key_here
RAPID_API_HOST=v3.football.api-sports.io

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
