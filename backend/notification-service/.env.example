# ── Server ───────────────────────────────────────────────
PORT=3003
NODE_ENV=development

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Match service ────────────────────────────────────────
# Use "http://match-service:3002" when running inside Docker Compose
# Use "http://localhost:3002" for local development outside Docker
MATCH_SERVICE_URL=http://localhost:3002

# ── JWT ──────────────────────────────────────────────────
# Must match the JWT_ACCESS_SECRET used in auth-service
JWT_SECRET=your_jwt_secret_here

# ── CORS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
