# ── Server ──────────────────────────────────────────────
PORT=3002
NODE_ENV=development

# ── API-Football (RapidAPI) ──────────────────────────────
# Get your key at: https://rapidapi.com/api-sports/api/api-football
RAPID_API_KEY=your_rapidapi_key_here

# ── Redis ────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000
