# ── API Gateway ──────────────────────────────────────────
# The Nginx config itself is static and does not consume these variables
# at runtime. Use them for documentation and for tooling (e.g. envsubst
# templates or docker-compose environment sections).

# ── CORS allowed origin ───────────────────────────────────
# Must match the origin your frontend is served from.
# Update the `map` block in conf.d/security-headers.conf to add new origins.
FRONTEND_URL=http://localhost:3000

# ── Upstream service addresses ────────────────────────────
# These match the Docker Compose service names — no changes needed
# when running inside Docker Compose. Update only for external deployments.
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=3001

MATCH_SERVICE_HOST=match-service
MATCH_SERVICE_PORT=3002

PREDICTION_SERVICE_HOST=prediction-service
PREDICTION_SERVICE_PORT=8000

NOTIFICATION_SERVICE_HOST=notification-service
NOTIFICATION_SERVICE_PORT=3003
