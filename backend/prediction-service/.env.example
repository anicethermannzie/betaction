# ── Service ──────────────────────────────────────────────
PORT=8000
DEBUG=false

# ── Match Service ─────────────────────────────────────────
# Use "http://match-service:3002" when running inside Docker Compose
# Use "http://localhost:3002" for local development outside Docker
MATCH_SERVICE_URL=http://localhost:3002
MATCH_SERVICE_TIMEOUT=10.0

# ── Redis ─────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Prediction cache ──────────────────────────────────────
PREDICTION_CACHE_TTL=1800   # seconds (30 minutes)

# ── Algorithm tuning ──────────────────────────────────────
LEAGUE_AVG_GOALS=1.5        # baseline average goals per team per match
