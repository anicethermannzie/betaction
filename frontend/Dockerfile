# =============================================================================
# BetAction — Frontend (Next.js 14)
# Three-stage build: deps → builder → production (standalone output)
#
# Requires next.config.ts to have:  output: 'standalone'
# =============================================================================

# ── Stage 1: deps — install dependencies only ─────────────────────────────────
FROM node:20-alpine AS deps

LABEL maintainer="BetAction Team"

# libc6-compat is needed by some native Node modules on Alpine
RUN apk add --no-cache libc6-compat

WORKDIR /app

# Copy manifests first — layer cache is invalidated only when these change
COPY package*.json ./

# Use npm install until package-lock.json is committed; switch to npm ci then
RUN npm install

# ── Stage 2: builder — compile the Next.js application ────────────────────────
FROM node:20-alpine AS builder

LABEL maintainer="BetAction Team"

WORKDIR /app

# Bring in installed modules from the deps stage
COPY --from=deps /app/node_modules ./node_modules

# Copy all source files
COPY . .

# Disable Next.js telemetry at build time
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# ── Stage 3: production — minimal runtime image ────────────────────────────────
FROM node:20-alpine AS production

LABEL maintainer="BetAction Team"

# curl is not included in node:20-alpine — install for health checks
RUN apk add --no-cache curl

# Create a least-privilege non-root user
RUN addgroup -S appgroup && adduser -S appuser -G appgroup

WORKDIR /app

ENV NODE_ENV=production \
    NEXT_TELEMETRY_DISABLED=1

# The standalone output bundles its own node_modules — copy it in full
COPY --from=builder --chown=appuser:appgroup /app/.next/standalone ./

# Static assets and public files must sit alongside the standalone server
COPY --from=builder --chown=appuser:appgroup /app/.next/static  ./.next/static
COPY --from=builder --chown=appuser:appgroup /app/public        ./public

# Run as non-root for security
USER appuser

EXPOSE 3000

HEALTHCHECK --interval=30s --timeout=10s --start-period=30s --retries=3 \
  CMD curl -f http://localhost:3000/ || exit 1

# server.js is generated by Next.js into the standalone root
CMD ["node", "server.js"]
